# Firefox Add-ons (AMO) API Credentials
# Get these from: https://addons.mozilla.org/developers/addon/api/key/
AMO_JWT_ISSUER=user:12345:67
AMO_JWT_SECRET=your-amo-jwt-secret-here

# Chrome Web Store API Credentials
# See CHROME_WEB_STORE.md for setup instructions
CHROME_CLIENT_ID=your-client-id.apps.googleusercontent.com
CHROME_CLIENT_SECRET=your-client-secret-here
CHROME_REFRESH_TOKEN=your-refresh-token-here
CHROME_EXTENSION_ID=your-extension-id-here

# Optional: Override default approval timeout (in milliseconds)
# APPROVAL_TIMEOUT=900000
